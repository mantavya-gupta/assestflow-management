generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id                String               @id @default(uuid())
  email             String               @unique
  password          String
  name              String
  role              Role                 @default(EMPLOYEE)
  status            UserStatus           @default(ACTIVE)
  departmentId      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  resetTokens       PasswordResetToken[]
  allocations       AssetAllocation[]
  transfersSent       Transfer[]           @relation("TransferFrom")
  transfersReceived   Transfer[]           @relation("TransferTo")
  department          Department?          @relation("UserDepartment", fields: [departmentId], references: [id])
  headedDepartments   Department[]         @relation("DepartmentHead")
  maintenanceAssigned MaintenanceRequest[] @relation("MaintenanceTechnician")
  bookings            ResourceBooking[]
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

model Department {
  id        String           @id @default(uuid())
  name      String           @unique
  status    DepartmentStatus @default(ACTIVE)
  headId    String?
  parentId  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  head      User?        @relation("DepartmentHead", fields: [headId], references: [id])
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  employees User[]       @relation("UserDepartment")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  MAINTENANCE
  RETIRED
  RESERVED
  LOST
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum TransferStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Asset {
  id              String      @id @default(uuid())
  assetTag        String      @unique
  name            String
  type            String
  status          AssetStatus @default(AVAILABLE)
  serialNumber    String?
  acquisitionDate DateTime?
  acquisitionCost Float?
  condition       String?
  location        String?
  shared          Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  allocations         AssetAllocation[]
  maintenanceRequests MaintenanceRequest[]
  transfers           Transfer[]
  bookings            ResourceBooking[]
}

model AssetAllocation {
  id                 String           @id @default(uuid())
  assetId            String
  assigneeId         String
  expectedReturnDate DateTime
  actualReturnDate   DateTime?
  returnNotes        String?
  status             AllocationStatus @default(ACTIVE)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  asset    Asset @relation(fields: [assetId], references: [id])
  assignee User  @relation(fields: [assigneeId], references: [id])
}

model MaintenanceRequest {
  id           String              @id @default(uuid())
  assetId      String
  issue        String
  priority     MaintenancePriority @default(MEDIUM)
  photoUrl     String?
  notes        String?
  status       MaintenanceStatus   @default(PENDING)
  technicianId String?
  reportedDate DateTime            @default(now())
  resolvedDate DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  asset      Asset @relation(fields: [assetId], references: [id])
  technician User? @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
}

model Transfer {
  id         String         @id @default(uuid())
  assetId    String
  fromUserId String
  toUserId   String
  status     TransferStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  asset    Asset @relation(fields: [assetId], references: [id])
  fromUser User  @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUser   User  @relation("TransferTo", fields: [toUserId], references: [id])
}

model ResourceBooking {
  id        String        @id @default(uuid())
  assetId   String
  userId    String
  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(UPCOMING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}
